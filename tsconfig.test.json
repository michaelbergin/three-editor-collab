{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "erasableSyntaxOnly": false,
    "module": "CommonJS",
    "moduleResolution": "node",
    "noEmit": false,
    "types": ["jest", "@testing-library/jest-dom", "node"],
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
