{
  "version": 1,
  "hooks": {
    "subagentStart": [
      {
        "command": ".cursor/hooks/subagent-audit.sh",
        "timeout": 3,
        "failClosed": false
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/file-scope-guard.sh",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "preToolUse": [
      {
        "command": ".cursor/hooks/tool-scope-guard.sh",
        "matcher": "Write|Delete|StrReplace|EditNotebook",
        "timeout": 5,
        "failClosed": false
      }
    ]
  }
}
